{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": [
    "dist"
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@i18n/*": [
        "./src/i18n/*"
      ],
      "@components/*": [
        "./src/components/*"
      ],
      "@consts/*": [
        "./src/consts/*"
      ],
      "@layouts/*": [
        "./src/layouts/*"
      ],
      "@types/*": [
        "./src/types/*"
      ],
      "@images/*": [
        "./src/images/*"
      ]
    },
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  }
}