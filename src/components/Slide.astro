---
import { Image } from "astro:assets";
import type { Language } from "../types/language.type";
import { i18n } from "../consts/i18n.files";

const { slide, alt } = Astro.props;

const locale = Astro.params.locale as Language;
const translate = i18n[locale];
---

<div class="swiper-slide relative overflow-hidden">
    <Image
        src={slide}
        class="hero-slide-image absolute inset-0 w-full h-full object-cover md:object-center object-center md:scale-105 scale-100"
        alt={alt}
    />

    <div class="absolute inset-0 bg-black/60"></div>

    <div
        class="absolute inset-0 bg-linear-to-t from-black/80 via-black/20 to-black/50"
    >
    </div>

    <div
        class="relative z-10 flex h-full items-center justify-center px-5 md:px-10"
    >
        <div
            class="w-full max-w-6xl flex flex-col items-center md:items-start text-center md:text-left pt-20 md:pt-0"
        >
            <div
                class="w-full flex overflow-hidden py-3 justify-center md:justify-start items-center"
            >
                <h1
                    class="max-w-[320px] md:max-w-4xl text-5xl sm:text-6xl md:text-7xl leading-[0.95] font-serif font-semibold tracking-tight text-white drop-shadow-[0_4px_20px_rgba(0,0,0,.7)] animate-fade-in-up-lg"
                >
                    {translate.sliders.home_slider.title}
                </h1>
            </div>

            <div
                class="flex justify-center md:justify-start my-5 md:my-7 w-full"
            >
                <span
                    class="h-px bg-yellow-400 origin-center slide-text-separator"
                ></span>
            </div>

            <div
                class="w-full flex overflow-hidden justify-center md:justify-start items-center"
            >
                <p
                    class="animate-fade-in-down max-w-xs sm:max-w-lg md:max-w-2xl text-base sm:text-lg md:text-3xl leading-relaxed font-light tracking-wide text-white/90 drop-shadow-[0_2px_12px_rgba(0,0,0,.8)]"
                >
                    {translate.sliders.home_slider.description}
                </p>
            </div>

            <div
                class="mt-8 md:mt-10 flex flex-col sm:flex-row items-center gap-3 md:gap-2"
            >
                <a
                    href={`/${locale}/registration/`}
                    class="rounded-full bg-yellow-400 px-7 py-3 text-sm md:text-base font-semibold text-black transition-all hover:bg-yellow-300"
                >
                    {translate.sliders.home_slider.registration}
                </a>

                <a
                    href={`/${locale}/contact/`}
                    class="rounded-full border border-white/20 bg-white/10 backdrop-blur-md px-7 py-3 text-sm md:text-base font-medium text-white transition-all hover:bg-white/20"
                >
                    {translate.sliders.home_slider.contact}
                </a>
            </div>
            <div class="w-full flex justify-start items-center px-2 py-5">
                <a
                    href="https://maps.app.goo.gl/s2DiSX15yhubjW3UA"
                    target="_blank"
                    class="text-sm text-white/70 hover:text-white transition-colors flex flex-col md:flex-row justify-center items-center gap-2"
                >
                    <i
                        class="icon-[material-symbols--location-on-outline-rounded] text-2xl md:text-base"
                    ></i>
                    <span class="text-base md:text-sm">
                        {translate.sliders.home_slider.direction}
                    </span>
                </a>
            </div>
        </div>
    </div>
</div>

<script is:inline>
    document.addEventListener("astro:page-load", () => {
        const $animated = document.querySelectorAll(".animate-fade-in-up-lg");
        setTimeout(() => {
            $animated.forEach((el, index) => {
                el.classList.remove("animate-fade-in-up-lg");
            });
        }, 800);
    });
</script>

<style>
    .slide-text-separator {
        animation: width-expand 0.8s ease-out forwards;
    }

    @keyframes width-expand {
        from {
            width: 0;
        }

        to {
            width: 140px;
        }
    }

    @media screen and (max-width: 768px) {
        @keyframes width-expand {
            from {
                width: 0;
            }

            to {
                width: 90px;
            }
        }
    }
</style>

<style is:global>
    .hero-slide-image {
        transform: scale(1);
        transition: transform 7s ease-out;
    }

    .swiper-slide-active .hero-slide-image {
        transform: scale(1.12);
    }
</style>
