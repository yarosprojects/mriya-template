---
import type { Language } from "../types/language.type";
import { labelsLocales } from "../consts/locales";
import Logotip from "@components/Logotip.astro";
import Navigation from "@components/Navigation.astro";
import navigation from "@consts/navigation";
import { i18n } from "../consts/i18n.files";
import Aside from "./Aside.astro";
import { navigate } from "astro:transitions/client";

const { detectedLocale = "" } = Astro.props;

const locale = (Astro.params.locale as Language) || detectedLocale;

const pathname = Astro.url.pathname;
const isBase = pathname === `/${locale}/`;
const translate = i18n[locale];
---

<header
    id="site-header"
    class={`shadow-md shadow-black/5 fixed top-0 left-0 z-9999 w-full px-3 md:py-0 py-2 ${!isBase ? "bg-white" : "hover:bg-black/90"}`}
>
    <div class="mx-auto flex w-full items-center">
        <div class="flex items-center gap-3">
            <button
                id="bars-button"
                type="button"
                class={`cursor-pointer max-[1200px]:flex size-11 items-center justify-center rounded-2xl transition-all duration-300 hidden ${isBase ? "hover:bg-white/10" : "hover:bg-black/8"}`}
            >
                <div class="flex flex-col gap-1.5 bars">
                    {
                        [1, 2, 3].map((item) => (
                            <span
                                class={`bar h-0.5 w-6 rounded-full transition-all duration-300 ${isBase ? "bg-white" : "bg-black"}`}
                            />
                        ))
                    }
                </div>
            </button>

            <div
                class="max-w-55 hover:scale-102 transition-transform duration-150 active:scale-95"
            >
                <a href={`/${locale}/`}>
                    <Logotip locale={locale} pathname={pathname} />
                </a>
            </div>
        </div>

        <Navigation detectedLocale={detectedLocale} />

        <div class="relative ml-auto">
            <button
                id="lang-switcher"
                type="button"
                class={`flex items-center gap-3 rounded-full border px-4 py-2 ${isBase ? "backdrop-blur-xl bg-black/20 border-white/10 hover:bg-black/35" : "hover:bg-black/15 border-black/10 bg-black/3"} transition-all duration-300 cursor-pointer`}
            >
                <div class="flex items-center gap-2">
                    <span
                        class={`text-sm font-medium ${isBase ? "text-white" : "text-black"}`}
                    >
                        {labelsLocales[locale].name}
                    </span>

                    {
                        labelsLocales[locale].multispoken && (
                            <span
                                class={`hidden text-[11px] uppercase tracking-wide ${isBase ? "text-white" : "text-black/50"} md:flex`}
                            >
                                {labelsLocales[locale].country.complex}
                            </span>
                        )
                    }
                </div>

                <i class={`${labelsLocales[locale].icon}`}></i>
            </button>

            <div
                id="lang-dropdown"
                class="absolute right-0 top-full mt-3 hidden min-w-56 overflow-hidden rounded-2xl border border-black/10 bg-white/95 p-1.5 shadow-[0_12px_30px_rgba(0,0,0,.12)] backdrop-blur-xl"
            >
                <div class="flex flex-col gap-0.5">
                    {
                        Object.values(labelsLocales).map((l) => {
                            const { code, name, country, multispoken, icon } =
                                l;

                            const newPath = pathname.replace(
                                /^\/[a-z]{2}-[A-Z]{2}/,
                                `/${code}`,
                            );

                            const active = locale === code;

                            return (
                                <a
                                    href={newPath}
                                    class={`group flex items-center justify-between rounded-xl px-3 py-2 transition-all duration-150 ${
                                        active
                                            ? "bg-white border border-black/15 text-black"
                                            : "hover:bg-black/5 border border-transparent"
                                    }`}
                                >
                                    <div class="flex items-center gap-2.5 min-h-8">
                                        <i
                                            class={`${icon} text-[18px] ${
                                                active ? "brightness-110" : ""
                                            }`}
                                        />

                                        <div class="flex flex-col">
                                            <span
                                                class={`text-[14px] font-medium leading-none ${
                                                    active
                                                        ? "text-red-500"
                                                        : "text-black"
                                                }`}
                                            >
                                                {name}
                                            </span>

                                            {multispoken && (
                                                <span
                                                    class={`mt-1 text-[9px] uppercase tracking-[0.14em] ${
                                                        active
                                                            ? "text-red-300"
                                                            : "text-black/50"
                                                    }`}
                                                >
                                                    {country.complex}
                                                </span>
                                            )}
                                        </div>
                                    </div>

                                    {active && (
                                        <i class="icon-[teenyicons--tick-small-outline]" />
                                    )}
                                </a>
                            );
                        })
                    }
                </div>
            </div>
        </div>
    </div>

    <div
        id="under-hero"
        class={`absolute top-full left-0 w-full overflow-hidden opacity-0 pointer-events-none transition-all shadow-md shadow-black/5 duration-300 ${isBase ? "bg-black/90 backdrop-blur-lg" : "bg-white"}`}
        style="height: 0px;"
    >
        <div
            class="mx-auto
            max-w-350
            px-8
            pt-10
            pb-12"
        >
            <div
                id="under-hero-content"
                class="grid
                grid-cols-2
                gap-16"
            >
            </div>
        </div>
    </div>
</header>

<Aside
    translate={translate}
    navigation={navigation}
    locale={locale}
    pathname={pathname}
/>
<div id="blurred-area" class="fixed z-9998 w-full h-screen backdrop-blur-2xl opacity-0 pointer-events-none hidden md:flex"></div>

<script is:inline define:vars={{ isBase, locale, pathname, translate }}>
    document.addEventListener("astro:page-load", () => {
        const header = document.getElementById("site-header");
        const langSwitcher = document.getElementById("lang-switcher");
        const dropdown = document.getElementById("lang-dropdown");
        const barsButton = document.getElementById("bars-button");
        const aside = document.getElementById("site-aside");
        const asideClose = document.getElementById("aside-close");
        const asideNavigation = document.getElementById("aside-navigation");
        const asideChildren = document.getElementById("aside-children");
        const asideChildrenContent = document.getElementById(
            "aside-children-content",
        );
        const asideBack = document.getElementById("aside-back");
        const clearAsideAnimations = () => {
            asideChildren.classList.remove(
                "animate-slide-in-bottom",
                "animate-slide-in-top",
                "animate-duration-200",
            );
        };

        const resetAside = () => {
            aside.classList.add("hidden");

            aside.classList.remove(
                "flex",
                "flex-col",
                "animate-fade-in-right",
                "animate-fade-out-left",
                "animate-duration-200",
            );

            clearAsideAnimations();

            asideNavigation.classList.remove(
                "hidden",
                "animate-slide-in-top",
                "animate-duration-200",
                "opacity-0",
            );

            asideChildren.classList.add("hidden");

            asideChildren.classList.remove(
                "animate-slide-in-bottom",
                "animate-slide-out-down",
                "animate-duration-200",
            );

            asideChildrenContent.innerHTML = "";

            document.body.classList.remove("overflow-hidden");
        };

        if (!langSwitcher || !dropdown) return;

        if (isBase) {
            const handleScroll = () => {
                if (window.scrollY > 180) {
                    header.classList.add("header-scrolled");
                } else {
                    header.classList.remove("header-scrolled");
                }
            };

            handleScroll();

            window.addEventListener("scroll", handleScroll);
        }

        langSwitcher.onclick = () => {
            dropdown.classList.toggle("hidden");
            dropdown.classList.toggle("animate-fade-in-down");
            dropdown.classList.toggle("animate-duration-200");
        };

        document.onclick = (event) => {
            if (
                !langSwitcher.contains(event.target) &&
                !dropdown.contains(event.target)
            ) {
                dropdown.classList.add("hidden");

                dropdown.classList.remove(
                    "animate-fade-in-down",
                    "animate-duration-200",
                );
            }
        };

        barsButton.addEventListener("click", () => {
            aside.classList.remove("hidden", "animate-fade-out-left");

            aside.classList.add(
                "flex",
                "flex-col",
                "animate-fade-in-right",
                "animate-duration-200",
            );

            document.body.classList.add("overflow-hidden");
        });

        asideClose.addEventListener("click", () => {
            aside.classList.remove("animate-fade-in-right");

            aside.classList.add(
                "animate-fade-out-left",
                "animate-duration-200",
            );

            setTimeout(() => {
                aside.classList.add("hidden");

                aside.classList.remove(
                    "flex",
                    "flex-col",
                    "animate-fade-out-left",
                    "animate-duration-200",
                );

                clearAsideAnimations();

                asideNavigation.classList.remove("hidden");

                asideChildren.classList.add("hidden");

                document.body.classList.remove("overflow-hidden");
            }, 200);
        });

        document.querySelectorAll(".aside-open-children").forEach((button) => {
            button.addEventListener("click", () => {
                clearAsideAnimations();

                const children = JSON.parse(button.dataset.children || "[]");

                asideChildrenContent.innerHTML = children
                    .map(
                        (child) => `
                            <a
                                href="/${locale}${child.href}"
                                class="group flex items-center justify-between rounded-3xl px-5 py-4 transition-all duration-200 hover:bg-black/4 active:scale-[0.985] ${
                                    pathname === `/${locale}${child.href}`
                                        ? "bg-red-500/8"
                                        : ""
                                }"
                            >
                                <div class="flex flex-col">
                                    <span class="text-[11px] uppercase tracking-[0.2em] text-black/35">
                                        ${translate.aside.page}
                                    </span>

                                    <span class="mt-1 text-[22px] leading-none font-bold tracking-tight ${
                                        pathname === `/${locale}${child.href}`
                                            ? "text-red-500"
                                            : "text-black"
                                    }">
                                        ${translate.header[child.translate_key]}
                                    </span>
                                </div>
                            </a>
                        `,
                    )
                    .join("");

                asideNavigation.classList.add("hidden");

                asideChildren.classList.remove("hidden");

                asideChildren.classList.add(
                    "animate-slide-in-bottom",
                    "animate-duration-200",
                );
            });
        });

        asideBack.addEventListener("click", () => {
            clearAsideAnimations();

            asideChildren.classList.add("hidden");
            asideNavigation.classList.remove("hidden");

            asideNavigation.classList.add(
                "opacity-0",
                "animate-slide-in-top",
                "animate-duration-200",
            );

            requestAnimationFrame(() => {
                asideNavigation.classList.remove("opacity-0");
            });

            asideChildren.classList.add(
                "animate-slide-out-down",
                "animate-duration-200",
            );

            setTimeout(() => {
                asideNavigation.classList.remove(
                    "animate-slide-in-top",
                    "animate-duration-200",
                );

                asideChildren.classList.add("hidden");

                asideChildren.classList.remove(
                    "animate-slide-out-down",
                    "animate-duration-200",
                );
            }, 200);
        });

        window.addEventListener("resize", () => {
            if (window.innerWidth >= 768) {
                resetAside();
            }
        });
    });
</script>

<style>
    #site-header {
        transition:
            background-color 0.3s ease,
            backdrop-filter 0.3s ease,
            border-color 0.3s ease;
    }

    .header-scrolled {
        background: #fff;
        backdrop-filter: blur(20px);
        border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    }

    .header-scrolled #lang-switcher {
        background: rgba(0, 0, 0, 0.03);
        border-color: rgba(0, 0, 0, 0.08);
    }

    .header-scrolled #under-hero {
        background-color: #fff;
    }

    .header-scrolled #under-hero * {
        color: #000 !important;
    }

    .header-scrolled #lang-switcher span {
        color: black;
    }

    .header-scrolled #lang-switcher i {
        color: black;
    }

    .header-scrolled #under-hero-content {
        color: black !important;
    }
</style>

<style is:global>
    .header-scrolled .bars .bar {
        background-color: black;
    }
</style>
