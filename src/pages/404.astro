---
import Layout from "../layouts/not-found/Layout.astro";
import { i18n } from "@consts/i18n.files";
import { defaultLocale, locales } from "@consts/locales";

const pathname = Astro.url.pathname;

const detectedLocale =
    locales.find((locale) => pathname.startsWith(`/${locale}/`)) ??
    defaultLocale;

const translate = i18n[detectedLocale];
---

<Layout>
    <section
        class="relative overflow-hidden min-h-screen w-full bg-neutral-100 flex justify-center items-center px-6 py-32"
    >
        <div class="absolute inset-0 pointer-events-none opacity-40">
            <div
                class="absolute -top-30 -left-30 w-100 h-100 rounded-full bg-yellow-400/20 blur-3xl"
            >
            </div>
            <div
                class="absolute -bottom-30 -right-30 w-100 h-100 rounded-full bg-blue-500/10 blur-3xl"
            >
            </div>
        </div>

        <div
            class="relative z-10 max-w-3xl flex flex-col justify-center items-center text-center"
        >
            <span
                class="text-[120px] md:text-[180px] leading-none font-black tracking-[-0.08em] text-black"
            >
                404
            </span>

            <div class="w-24 h-0.5 bg-yellow-400 rounded-full mb-8"></div>

            <h1
                class="text-4xl md:text-6xl font-black text-black uppercase tracking-tight"
            >
                {translate.errors.not_found}
            </h1>

            <p
                class="mt-6 text-neutral-500 text-lg md:text-xl leading-relaxed max-w-xl"
            >
                {translate.errors.not_found_description}
            </p>

            <div
                class="mt-12 flex flex-col sm:flex-row justify-center items-center gap-4"
            >
                <a
                    href={`/${detectedLocale}/`}
                    class="px-8 py-4 rounded-full bg-black text-white uppercase text-sm tracking-widest hover:bg-yellow-400 hover:text-black transition-all duration-300"
                >
                    {translate.header.home}
                </a>

                <a
                    href={`/${detectedLocale}/contact/`}
                    class="px-8 py-4 rounded-full border border-black/10 bg-white/70 backdrop-blur text-black uppercase text-sm tracking-widest hover:border-yellow-400 hover:text-yellow-500 transition-all duration-300"
                >
                    {translate.header.contact}
                </a>
            </div>

            <div
                class="mt-16 text-xs uppercase tracking-[0.4em] text-neutral-400"
            >
                {translate.school_name_variants.footer_full_name}
            </div>
        </div>
    </section>
</Layout>
