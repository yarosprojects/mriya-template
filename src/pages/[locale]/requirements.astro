---
// export { getLocaleStaticPaths as getStaticPaths } from "@/src/utils/getLocaleStaticPaths";
import Layout from "@layouts/Layout.astro";
import { i18n } from "@consts/i18n.files";
import type { Language } from "@/src/types/language.type";

const locale = Astro.params.locale as Language;
const translate = i18n[locale];
---

<Layout title="Requirements">
    <section
        class="relative overflow-hidden bg-linear-to-b from-black/5 via-white to-black/5 px-0 md:px-10 pt-42 md:pt-52 pb-0 md:pb-28"
    >
        <div
            class="absolute top-0 left-1/2 -translate-x-1/2 w-180 h-180 rounded-full bg-yellow-400/10 blur-3xl"
        >
        </div>

        <div class="relative z-10 max-w-7xl mx-auto">
            <div class="flex flex-col justify-center items-center text-center px-2 md:px-0">
                <span
                    class="px-6 py-3 rounded-full border border-yellow-400/40 bg-yellow-400/10 text-yellow-600 uppercase tracking-[0.3em] text-xs md:text-sm font-bold"
                >
                    {translate.requirements.badge}
                </span>

                <h1
                    class="mt-8 text-5xl md:text-7xl font-black tracking-tight text-black leading-none animate-fade-in-up"
                >
                    {translate.requirements.title}
                </h1>

                <div class="max-w-28 w-full mx-auto flex justify-center items-center">
                    <div class="mt-8 w-full h-1 rounded-full bg-yellow-400 origin-center md:animate-width"></div>
                </div>

                <p
                    class="mt-10 max-w-4xl text-lg md:text-2xl leading-[1.8] text-neutral-600 animate-fade-in-down"
                >
                    {translate.requirements.description}
                </p>
            </div>

            <div
                class="mt-24 grid grid-cols-1 lg:grid-cols-[1fr_420px] gap-10 items-start"
            >
                <div class="flex flex-col md:px-0 px-2">
                    <div
                        class="relative overflow-hidden rounded-[40px] border border-black/5 bg-white/70 backdrop-blur-xl shadow-[0_20px_80px_rgba(0,0,0,.05)]"
                    >
                        <div
                            class="absolute top-0 left-0 w-full h-1 bg-linear-to-r from-yellow-400 via-yellow-300 to-yellow-400"
                        >
                        </div>

                        <div class="px-4 py-8 md:p-12">
                            <div class="flex items-center gap-4">
                                <div
                                    class="flex items-center justify-center md:w-16 md:h-16 w-30 h-15 rounded-2xl bg-yellow-400/15"
                                >
                                    <i
                                        class="icon-[solar--documents-bold] text-4xl text-yellow-500"
                                    ></i>
                                </div>

                                <div>
                                    <span
                                        class="uppercase tracking-[0.25em] text-xs text-yellow-600 font-bold"
                                    >
                                        {translate.requirements.documents.badge}
                                    </span>

                                    <h2
                                        class="mt-2 text-3xl md:text-4xl font-black text-black"
                                    >
                                        {translate.requirements.documents.title}
                                    </h2>
                                </div>
                            </div>

                            <div class="mt-12 flex flex-col gap-5">
                                <div
                                    class="group flex flex-col md:flex-row items-start gap-5 rounded-3xl border border-black/5 bg-black/1.5 px-6 py-6 transition-all hover:bg-yellow-400/5 hover:border-yellow-400/20"
                                >
                                    <div
                                        class="flex items-center justify-center min-w-14 h-14 rounded-2xl bg-yellow-400 text-black font-black text-xl"
                                    >
                                        1
                                    </div>

                                    <div>
                                        <h3
                                            class="text-xl md:text-2xl font-bold text-black"
                                        >
                                            {
                                                translate.requirements.documents
                                                    .items.first.title
                                            }
                                        </h3>

                                        <p
                                            class="mt-3 text-neutral-600 leading-relaxed"
                                        >
                                            {
                                                translate.requirements.documents
                                                    .items.first.description
                                            }
                                        </p>
                                    </div>
                                </div>

                                <div
                                    class="group flex flex-col md:flex-row items-start gap-5 rounded-3xl border border-black/5 bg-black/1.5 px-6 py-6 transition-all hover:bg-yellow-400/5 hover:border-yellow-400/20"
                                >
                                    <div
                                        class="flex items-center justify-center min-w-14 h-14 rounded-2xl bg-yellow-400 text-black font-black text-xl"
                                    >
                                        2
                                    </div>

                                    <div>
                                        <h3
                                            class="text-xl md:text-2xl font-bold text-black"
                                        >
                                            {
                                                translate.requirements.documents
                                                    .items.second.title
                                            }
                                        </h3>

                                        <p
                                            class="mt-3 text-neutral-600 leading-relaxed"
                                        >
                                            {
                                                translate.requirements.documents
                                                    .items.second.description
                                            }
                                        </p>
                                    </div>
                                </div>

                                <div
                                    class="group flex flex-col md:flex-row items-start gap-5 rounded-3xl border border-black/5 bg-black/1.5 px-6 py-6 transition-all hover:bg-yellow-400/5 hover:border-yellow-400/20"
                                >
                                    <div
                                        class="flex items-center justify-center min-w-14 h-14 rounded-2xl bg-yellow-400 text-black font-black text-xl"
                                    >
                                        3
                                    </div>

                                    <div>
                                        <h3
                                            class="text-xl md:text-2xl font-bold text-black"
                                        >
                                            {
                                                translate.requirements.documents
                                                    .items.third.title
                                            }
                                        </h3>

                                        <p
                                            class="mt-3 text-neutral-600 leading-relaxed"
                                        >
                                            {
                                                translate.requirements.documents
                                                    .items.third.description
                                            }
                                        </p>
                                    </div>
                                </div>

                                <div
                                    class="group flex flex-col md:flex-row items-start gap-5 rounded-3xl border border-black/5 bg-black/1.5 px-6 py-6 transition-all hover:bg-yellow-400/5 hover:border-yellow-400/20"
                                >
                                    <div
                                        class="flex items-center justify-center min-w-14 h-14 rounded-2xl bg-yellow-400 text-black font-black text-xl"
                                    >
                                        4
                                    </div>

                                    <div>
                                        <h3
                                            class="text-xl md:text-2xl font-bold text-black"
                                        >
                                            {
                                                translate.requirements.documents
                                                    .items.fourth.title
                                            }
                                        </h3>

                                        <p
                                            class="mt-3 text-neutral-600 leading-relaxed"
                                        >
                                            {
                                                translate.requirements.documents
                                                    .items.fourth.description
                                            }
                                        </p>
                                    </div>
                                </div>

                                <div
                                    class="group flex flex-col md:flex-row items-start gap-5 rounded-3xl border border-yellow-400/20 bg-yellow-400/5 px-6 py-6"
                                >
                                    <div
                                        class="flex items-center justify-center min-w-14 h-14 rounded-2xl bg-yellow-400 text-black"
                                    >
                                        <i
                                            class="icon-[solar--star-bold] text-2xl"
                                        ></i>
                                    </div>

                                    <div>
                                        <h3
                                            class="text-xl md:text-2xl font-bold text-black"
                                        >
                                            {
                                                translate.requirements.documents
                                                    .items.fifth.title
                                            }
                                        </h3>

                                        <p
                                            class="mt-3 text-neutral-700 leading-relaxed"
                                        >
                                            {
                                                translate.requirements.documents
                                                    .items.fifth.description
                                            }
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <aside class="flex flex-col gap-8">
                    <div
                        class="relative overflow-hidden rounded-[36px] border border-black/5 bg-white/70 p-8 backdrop-blur-xl shadow-[0_20px_80px_rgba(0,0,0,.05)]"
                    >
                        <div
                            class="absolute top-0 right-0 w-40 h-40 bg-yellow-400/10 blur-3xl rounded-full"
                        >
                        </div>

                        <div class="relative z-10">
                            <div
                                class="flex items-center justify-center w-18 h-18 rounded-3xl bg-yellow-400 text-black"
                            >
                                <i
                                    class="icon-[solar--users-group-rounded-bold] text-4xl"
                                ></i>
                            </div>

                            <h3
                                class="mt-8 text-3xl font-black text-black leading-tight"
                            >
                                {translate.requirements.parents_meeting.title}
                            </h3>

                            <p
                                class="mt-5 text-lg text-neutral-600 leading-relaxed"
                            >
                                {
                                    translate.requirements.parents_meeting
                                        .description
                                }
                            </p>
                        </div>
                    </div>

                    <div
                        class="md:rounded-[36px] border border-black/5 bg-black text-white p-8 shadow-[0_20px_80px_rgba(0,0,0,.08)]"
                    >
                        <span
                            class="uppercase tracking-[0.25em] text-xs text-yellow-300 font-bold"
                        >
                            {translate.requirements.important.badge}
                        </span>

                        <h3 class="mt-5 text-3xl font-black leading-tight">
                            {translate.requirements.important.title}
                        </h3>

                        <p class="mt-5 text-white/70 leading-relaxed text-lg">
                            {translate.requirements.important.description}
                        </p>

                        <div class="mt-8 h-px w-full bg-white/10"></div>

                        <div class="mt-8 flex items-center gap-4 text-white/70">
                            <i
                                class="icon-[solar--check-circle-bold] text-2xl text-yellow-300"
                            ></i>

                            <span>
                                {translate.requirements.important.footer}
                            </span>
                        </div>
                    </div>
                </aside>
            </div>
        </div>
    </section>
</Layout>
