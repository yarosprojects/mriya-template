---
// export { getLocaleStaticPaths as getStaticPaths } from "@/src/utils/getLocaleStaticPaths";
import Layout from "@layouts/Layout.astro";
import { i18n } from "@consts/i18n.files";
import type { Language } from "@/src/types/language.type";
import { Image } from "astro:assets";
import logotip_transparent from "@images/logotip-transparent.png";
import slide_1 from "@images/slides/home/slide-1.jpg";
import slide_2 from "@images/slides/home/slide-2.jpg";
import slide_3 from "@images/slides/home/slide-3.jpg";
import slide_4 from "@images/slides/home/slide-4.jpg";
import slide_5 from "@images/slides/home/slide-5.jpg";
import Slide from "@/src/components/Slide.astro";
import Swiper from "swiper";
import { Autoplay, EffectFade, Pagination } from "swiper/modules";
import "swiper/css";
import "swiper/css/effect-fade";

const locale = Astro.params.locale as Language;
const translate = i18n[locale];
---

<Layout title={translate.site_titels.home}>
	<section class="relative w-full h-screen overflow-hidden">
		<div class="swiper hero-swiper w-full h-full opacity-0">
			<div class="swiper-wrapper">
				<Slide slide={slide_1} alt="Slide 1" />
				<Slide slide={slide_2} alt="Slide 2" />
				<Slide slide={slide_3} alt="Slide 3" />
				<Slide slide={slide_4} alt="Slide 3" />
				<Slide slide={slide_5} alt="Slide 3" />
			</div>

			<div
				class="hero-pagination absolute bottom-10 left-1/2 z-30 flex -translate-x-1/2 gap-3"
			>
			</div>
		</div>
	</section>

	<section
		class="relative bg-linear-to-b from-black/5 via-white to-black/5 flex justify-center items-center overflow-hidden py-24 md:py-40 px-5 md:px-10"
	>
		<div
			class="absolute top-0 left-1/2 -translate-x-1/2 w-175 h-175 bg-yellow-400/10 blur-3xl rounded-full"
		>
		</div>

		<div
			class="relative z-10 max-w-7xl w-full grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center"
		>
			<div class="relative flex justify-center items-center">
				<div
					class="absolute w-80 h-80 md:w-125 md:h-125 rounded-full bg-blue-500/5 blur-3xl"
				>
				</div>

				<div
					class="relative rounded-[40px] backdrop-blur-xl p-8 md:p-14"
				>
					<Image
						src={logotip_transparent}
						alt="Logotip"
						class="w-72 md:w-130 object-contain drop-shadow-[0_10px_40px_rgba(0,0,0,.08)]"
					/>
				</div>
			</div>

			<div class="flex flex-col justify-center items-start">
				<span
					class="px-5 py-2 rounded-full border border-yellow-400/40 bg-yellow-400/10 text-yellow-600 uppercase tracking-[0.3em] text-xs md:text-sm font-bold"
				>
					{translate.school_name_variants.ukrainian_school}
				</span>

				<h2
					class="mt-6 text-4xl md:text-6xl leading-none font-black tracking-tight text-black max-w-2xl"
				>
					{translate.home.title}
				</h2>

				<div class="w-24 h-1 rounded-full bg-yellow-400 mt-8"></div>

				<div
					class="mt-10 flex flex-col gap-8 text-neutral-700 text-lg md:text-2xl leading-[1.8] font-medium"
				>
					<p>{translate.home.subtitle}</p>

					<p class="text-neutral-600 font-normal">
						{translate.home.description}
					</p>

					<p class="text-neutral-600 font-normal">
						{translate.home.description_2}
					</p>
				</div>
			</div>
		</div>
	</section>

	<section
		class="relative overflow-hidden py-24 md:py-36 px-5 md:px-10 bg-white"
	>
		<div
			class="absolute top-20 left-10 w-72 h-72 rounded-full bg-yellow-400/10 blur-3xl"
		>
		</div>

		<div
			class="absolute bottom-10 right-10 w-96 h-96 rounded-full bg-blue-500/10 blur-3xl"
		>
		</div>

		<div
			class="relative z-10 max-w-7xl mx-auto flex flex-col items-center text-center"
		>
			<span
				class="px-5 py-2 rounded-full border border-yellow-400/40 bg-yellow-400/10 text-yellow-600 uppercase tracking-[0.3em] text-xs md:text-sm font-bold"
			>
				{translate.school_name_variants.ukrainian_school}
			</span>

			<h2
				class="mt-6 text-4xl md:text-6xl font-black tracking-tight text-black max-w-4xl leading-tight"
			>
				{translate.home.education.title}
			</h2>

			<div class="w-24 h-1 rounded-full bg-yellow-400 mt-8"></div>

			<p
				class="mt-10 max-w-4xl text-neutral-600 text-lg md:text-2xl leading-[1.9]"
			>
				{translate.home.education.description}
			</p>
		</div>

		<div
			class="relative z-10 max-w-7xl mx-auto mt-24 grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6"
		>
			<div
				class="rounded-[34px] bg-black/2 border border-black/5 p-8 hover:-translate-y-2 transition-all duration-500"
			>
				<div
					class="w-18 h-18 rounded-3xl bg-yellow-400/15 text-yellow-600 flex justify-center items-center text-4xl"
				>
					<i class="icon-[solar--book-bold]"></i>
				</div>

				<h3 class="mt-8 text-2xl font-black text-black">
					{translate.home.cards.education.title}
				</h3>

				<p class="mt-5 text-neutral-600 leading-[1.9]">
					{translate.home.cards.education.description}
				</p>
			</div>

			<div
				class="rounded-[34px] bg-black/2 border border-black/5 p-8 hover:-translate-y-2 transition-all duration-500"
			>
				<div
					class="w-18 h-18 rounded-3xl bg-blue-500/10 text-blue-600 flex justify-center items-center text-4xl"
				>
					<i class="icon-[solar--users-group-rounded-bold]"></i>
				</div>

				<h3 class="mt-8 text-2xl font-black text-black">
					{translate.home.cards.community.title}
				</h3>

				<p class="mt-5 text-neutral-600 leading-[1.9]">
					{translate.home.cards.community.description}
				</p>
			</div>

			<div
				class="rounded-[34px] bg-black/2 border border-black/5 p-8 hover:-translate-y-2 transition-all duration-500"
			>
				<div
					class="w-18 h-18 rounded-3xl bg-red-500/10 text-red-500 flex justify-center items-center text-4xl"
				>
					<i class="icon-[solar--medal-ribbons-star-bold]"></i>
				</div>

				<h3 class="mt-8 text-2xl font-black text-black">
					{translate.home.cards.teachers.title}
				</h3>

				<p class="mt-5 text-neutral-600 leading-[1.9]">
					{translate.home.cards.teachers.description}
				</p>
			</div>

			<div
				class="rounded-[34px] bg-black/2 border border-black/5 p-8 hover:-translate-y-2 transition-all duration-500"
			>
				<div
					class="w-18 h-18 rounded-3xl bg-emerald-500/10 text-emerald-600 flex justify-center items-center text-4xl"
				>
					<i class="icon-[solar--global-bold]"></i>
				</div>

				<h3 class="mt-8 text-2xl font-black text-black">
					{translate.home.cards.international.title}
				</h3>

				<p class="mt-5 text-neutral-600 leading-[1.9]">
					{translate.home.cards.international.description}
				</p>
			</div>
		</div>
	</section>

	<section
		class="relative overflow-hidden pt-24 pb-0 md:py-36 px-0 md:px-10 bg-black/2"
	>
		<div
			class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-10 items-center"
		>
			<div class="flex flex-col items-start px-5 md:px-0">
				<span
					class="px-5 py-2 rounded-full border border-yellow-400/40 bg-yellow-400/10 text-yellow-600 uppercase tracking-[0.3em] text-xs md:text-sm font-bold"
				>
					{translate.home.family.badge}
				</span>

				<h2
					class="mt-6 text-4xl md:text-6xl font-black text-black leading-tight"
				>
					{translate.home.family.title}
				</h2>

				<p
					class="mt-8 text-neutral-600 text-lg md:text-xl leading-[1.9]"
				>
					{translate.home.family.description}
				</p>

				<div class="mt-12 grid grid-cols-2 gap-6 w-full">
					<div class="rounded-3xl bg-white border border-black/5 p-6">
						<h3 class="text-4xl font-black text-black">10+</h3>

						<p class="mt-3 text-neutral-500">
							{translate.home.family.stats.years}
						</p>
					</div>

					<div class="rounded-3xl bg-white border border-black/5 p-6">
						<h3 class="text-4xl font-black text-black">200+</h3>

						<p class="mt-3 text-neutral-500">
							{translate.home.family.stats.students}
						</p>
					</div>

					<div class="rounded-3xl bg-white border border-black/5 p-6">
						<h3 class="text-4xl font-black text-black">100%</h3>

						<p class="mt-3 text-neutral-500">
							{translate.home.family.stats.program}
						</p>
					</div>

					<div class="rounded-3xl bg-white border border-black/5 p-6">
						<h3 class="text-4xl font-black text-black">20+</h3>

						<p class="mt-3 text-neutral-500">
							{translate.home.family.stats.teachers}
						</p>
					</div>
				</div>
			</div>

			<div class="relative">
				<div
					class="absolute inset-0 rounded-[40px] bg-linear-to-br from-yellow-400/20 to-blue-500/10 blur-2xl"
				>
				</div>

				<div
					class="relative md:rounded-[40px] overflow-hidden md:border md:border-black/5 shadow-[0_20px_80px_rgba(0,0,0,.08)]"
				>
					<Image
						src={slide_2}
						alt="Mriya School"
						class="w-full h-150 object-cover"
					/>
				</div>
			</div>
		</div>
	</section>

	<section
		class="relative overflow-hidden py-0 md:py-36 px-0 md:px-10 bg-white"
	>
		<div
			class="max-w-6xl mx-auto md:rounded-[50px] bg-black text-white overflow-hidden"
		>
			<div class="grid grid-cols-1 lg:grid-cols-2">
				<div class="p-10 md:p-16 flex flex-col justify-center">
					<span
						class="uppercase tracking-[0.3em] text-xs font-bold text-yellow-400"
					>
						{translate.home.registration.badge}
					</span>

					<h2
						class="mt-6 text-4xl md:text-6xl font-black leading-tight"
					>
						{translate.home.registration.title}
					</h2>

					<p class="mt-8 text-white/70 text-lg leading-[1.9]">
						{translate.home.registration.description}
					</p>

					<div class="mt-10 flex flex-wrap gap-4">
						<a
							href={`/${locale}/registration/`}
							class="px-8 py-4 rounded-full bg-yellow-400 text-black font-bold hover:bg-yellow-300 transition-colors"
						>
							{translate.home.registration.join}
						</a>

						<a
							href={`/${locale}/contact/`}
							class="px-8 py-4 rounded-full border border-white/10 bg-white/5 hover:bg-white/10 transition-colors"
						>
							{translate.home.registration.contact}
						</a>
					</div>
				</div>

				<div class="hidden md:flex relative min-h-100">
					<Image
						src={slide_5}
						alt="Students"
						class="absolute inset-0 w-full h-full object-cover"
					/>

					<div
						class="absolute inset-0 bg-linear-to-t from-black/70 via-black/20 to-transparent"
					>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>

<script>
	import Swiper from "swiper";
	import { Autoplay, EffectFade, Pagination } from "swiper/modules";

	const initHeroSwiper = () => {
		const swiperEl = document.querySelector(
			".hero-swiper",
		) as HTMLElement & {
			swiper?: Swiper;
		};

		if (!swiperEl) return;

		if (swiperEl.swiper) {
			swiperEl.swiper.destroy(true, true);
		}

		new Swiper(swiperEl, {
			modules: [Autoplay, EffectFade, Pagination],

			effect: "fade",
			loop: true,
			speed: 2000,

			autoplay: {
				delay: 4000,
				disableOnInteraction: false,
			},

			pagination: {
				el: ".hero-pagination",
				clickable: true,
			},

			on: {
				init() {
					swiperEl.classList.remove("opacity-0");
				},
			},
		});
	};
	document.addEventListener("astro:after-swap", initHeroSwiper);
	initHeroSwiper();
</script>

<style is:global>
	.hero-pagination .swiper-pagination-bullet {
		width: 12px;
		height: 12px;
		background: rgba(255, 255, 255, 0.5);
		opacity: 1;
		transition: all 0.3s ease;
		border-radius: 50%;
	}

	.hero-pagination .swiper-pagination-bullet-active {
		background-color: #facc15;
		transform: scale(1.2);
	}

	.hero-swiper {
		transition: opacity 0.3s ease;
	}
</style>
