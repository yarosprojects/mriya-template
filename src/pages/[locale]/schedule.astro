---
// export { getLocaleStaticPaths as getStaticPaths } from "@/src/utils/getLocaleStaticPaths";

import Layout from "@layouts/Layout.astro";
import type { Language } from "@/src/types/language.type";
import { i18n } from "@/src/consts/i18n.files";
import { schedules } from "@/src/consts/schedules";

const locale = Astro.params.locale as Language;
const translate = i18n[locale];
const horario = schedules(translate);
---

<Layout title="Schedule">
    <section class="relative overflow-hidden px-5 pb-24 pt-40 md:px-10">
        <div
            class="absolute left-1/2 top-0 h-120 w-120 -translate-x-1/2 rounded-full bg-yellow-400/10 blur-3xl"
        >
        </div>

        <div class="relative z-10 mx-auto max-w-7xl">
            <div class="flex flex-col items-center text-center">
                <span
                    class="animate-fade-in mb-5 rounded-full border border-yellow-400/30 bg-yellow-400/10 px-5 py-2 text-sm font-medium tracking-[0.25em] uppercase text-yellow-600 animate-duration-200"
                >
                    {translate.school_name_variants.ukrainian_school}
                    <b>{translate.school_name_variants.name}</b>
                </span>

                <h1
                    class="mt-8 font-heading text-5xl leading-[0.9] font-black tracking-tighter text-black md:text-7xl"
                >
                    {translate.schedule.title}

                    <span class="my-4 block">
                        {new Date().getFullYear()}
                        {translate.schedule.year}
                    </span>
                </h1>

                <p class="mt-8 max-w-3xl text-lg leading-[1.9] text-black/55">
                    {translate.schedule.description}
                </p>
            </div>

            <div class="relative mt-20">
                <div
                    id="schedule-tabs"
                    class="relative scrollbar-none flex snap-x snap-mandatory items-center gap-3 overflow-x-auto px-4 py-2 scroll-smooth md:px-10"
                >
                    {
                        horario.map((item, index) => (
                            <button
                                type="button"
                                data-tab={index}
                                class={`schedule-tab shrink-0 cursor-pointer rounded-full border px-5 py-3 text-[11px] font-bold uppercase tracking-[0.25em] transition-all duration-300 md:px-7 md:py-4 md:text-sm ${
                                    index === 0
                                        ? "border-yellow-400 bg-yellow-400 text-black shadow-[0_10px_30px_rgba(250,204,21,.3)]"
                                        : "border-black/10 bg-white/70 text-black/55 hover:bg-black hover:text-white"
                                }`}
                            >
                                {item.course}
                            </button>
                        ))
                    }
                </div>
            </div>

            <div class="relative mt-10 overflow-hidden md:mt-16">
                <div
                    id="schedule-slider"
                    class="flex transition-transform duration-150 ease-out"
                >
                    {
                        horario.map((schedule) => (
                            <div class="w-full shrink-0 px-1">
                                <div class="overflow-hidden rounded-[42px] border border-black/6 bg-white shadow-[0_20px_60px_rgba(0,0,0,.05)]">
                                    <div class="relative overflow-hidden border-b border-black/6 px-6 py-8 md:px-12 md:py-10">
                                        <div class="absolute right-0 top-0 h-40 w-40 rounded-full bg-yellow-400/10 blur-3xl" />

                                        <div class="relative z-10">
                                            <span class="text-xs font-black uppercase tracking-[0.35em] text-yellow-600">
                                                {translate.schedule.card.badge}
                                            </span>

                                            <h2 class="mt-4 font-heading text-5xl leading-none font-black text-black md:text-6xl">
                                                {schedule.course}
                                            </h2>

                                            <p class="mt-4 text-base leading-relaxed text-black/45">
                                                {translate.schedule.card.school}
                                            </p>
                                        </div>
                                    </div>

                                    <div class="flex flex-col">
                                        {schedule.lessons.map((item, index) =>
                                            item.type === "lesson" ? (
                                                <div
                                                    class={`group grid grid-cols-1 items-start gap-5 px-6 py-9 transition-all duration-300 hover:bg-black/2 md:grid-cols-[140px_1fr] md:items-center md:px-12 md:py-7 ${
                                                        index !==
                                                        schedule.lessons
                                                            .length -
                                                            1
                                                            ? "border-b border-black/6"
                                                            : ""
                                                    }`}
                                                >
                                                    <div class="flex h-14 w-full items-center justify-center rounded-2xl border border-yellow-400/20 bg-yellow-400/10 text-xl font-black tracking-tight text-yellow-700">
                                                        {item.time}
                                                    </div>

                                                    <div class="flex items-center gap-5">
                                                        <div class="flex size-13 items-center justify-center rounded-2xl bg-black text-white transition-transform duration-300 group-hover:scale-105">
                                                            <i class="icon-[solar--book-bookmark-bold] text-xl" />
                                                        </div>

                                                        <div>
                                                            <h3 class="text-2xl font-black tracking-tight text-black">
                                                                {item.title}
                                                            </h3>

                                                            {/* <p class="mt-1 text-sm tracking-wide text-black/40">
                                                                {
                                                                    translate
                                                                        .schedule
                                                                        .card
                                                                        .lesson_school
                                                                }
                                                            </p> */}
                                                        </div>
                                                    </div>
                                                </div>
                                            ) : (
                                                <div class="relative flex items-center justify-center py-6">
                                                    <div class="absolute left-12 right-12 h-px bg-linear-to-r from-transparent via-yellow-400/40 to-transparent" />

                                                    <div class="relative z-10 flex items-center gap-3 rounded-full border border-yellow-400/20 bg-yellow-400/10 px-5 py-3 backdrop-blur-sm">
                                                        <div class="flex size-10 items-center justify-center rounded-full bg-yellow-400 text-black">
                                                            <i class="icon-[solar--cup-hot-bold] text-lg" />
                                                        </div>

                                                        <div>
                                                            <p class="text-sm font-black uppercase tracking-[0.2em] text-yellow-700">
                                                                {item.label}
                                                            </p>

                                                            <span class="text-xs text-black/45">
                                                                {item.duration}
                                                            </span>
                                                        </div>
                                                    </div>
                                                </div>
                                            ),
                                        )}
                                    </div>
                                </div>
                            </div>
                        ))
                    }
                </div>

                <div
                    class="flex flex-col items-center justify-center gap-4 py-10 md:flex-row"
                >
                    <button
                        type="button"
                        class="prev-slide group flex cursor-pointer items-center gap-3 rounded-full bg-black px-8 py-4 text-sm font-bold uppercase tracking-[0.25em] text-white transition-all duration-300 hover:scale-[1.02] hover:bg-black/90"
                    >
                        <i
                            class="icon-[solar--arrow-left-linear] text-xl transition-transform duration-300 group-hover:translate-x-1"
                        ></i>

                        {translate.schedule.card.previous_class}
                    </button>

                    <button
                        type="button"
                        class="next-slide group flex cursor-pointer items-center gap-3 rounded-full border-yellow-400 bg-yellow-400 px-8 py-4 text-sm font-bold uppercase tracking-[0.25em] text-black shadow-[0_10px_30px_rgba(250,204,21,.3)] transition-all duration-300 hover:scale-[1.02]"
                    >
                        {translate.schedule.card.next_class}

                        <i
                            class="icon-[solar--arrow-right-linear] text-xl transition-transform duration-300 group-hover:translate-x-1"
                        ></i>
                    </button>
                </div>
            </div>
        </div>
    </section>
</Layout>

<script is:inline>
    document.addEventListener("astro:page-load", () => {
        const tabs = document.querySelectorAll(".schedule-tab");
        const slider = document.getElementById("schedule-slider");
        const nextButtons = document.querySelectorAll(".next-slide");
        const prevButtons = document.querySelectorAll(".prev-slide");

        let activeIndex = 0;

        const updateSlider = () => {
            if (!slider) return;

            slider.style.transform = `translateX(-${activeIndex * 100}%)`;

            tabs.forEach((tab, index) => {
                tab.classList.remove(
                    "border-yellow-400",
                    "bg-yellow-400",
                    "text-black",
                    "shadow-[0_10px_30px_rgba(250,204,21,.3)]",
                );

                tab.classList.remove(
                    "border-black/10",
                    "bg-white/70",
                    "text-black/55",
                );

                if (index === activeIndex) {
                    tab.classList.add(
                        "border-yellow-400",
                        "bg-yellow-400",
                        "text-black",
                        "shadow-[0_10px_30px_rgba(250,204,21,.3)]",
                    );

                    tab.scrollIntoView({
                        behavior: "smooth",
                        inline: "center",
                        block: "nearest",
                    });
                } else {
                    tab.classList.add(
                        "border-black/10",
                        "bg-white/70",
                        "text-black/55",
                    );
                }
            });
        };

        tabs.forEach((tab, index) => {
            tab.addEventListener("click", () => {
                activeIndex = index;

                updateSlider();
            });
        });

        nextButtons.forEach((button) => {
            button.addEventListener("click", () => {
                if (activeIndex < tabs.length - 1) {
                    activeIndex++;

                    updateSlider();
                }
            });
        });

        prevButtons.forEach((button) => {
            button.addEventListener("click", () => {
                if (activeIndex > 0) {
                    activeIndex--;

                    updateSlider();
                }
            });
        });

        let startX = 0;
        let currentX = 0;
        let dragging = false;

        slider?.addEventListener("touchstart", (e) => {
            dragging = true;
            startX = e.touches[0].clientX;
        });

        slider?.addEventListener("touchmove", (e) => {
            if (!dragging) return;

            currentX = e.touches[0].clientX;
        });

        slider?.addEventListener("touchend", () => {
            if (!dragging) return;

            const diff = startX - currentX;

            if (diff > 50 && activeIndex < tabs.length - 1) {
                activeIndex++;
            }

            if (diff < -50 && activeIndex > 0) {
                activeIndex--;
            }

            updateSlider();

            dragging = false;
        });

        updateSlider();
    });
</script>

<style>
    .scrollbar-none::-webkit-scrollbar {
        display: none;
    }

    .scrollbar-none {
        scrollbar-width: none;
    }

    #schedule-tabs {
        mask-image: linear-gradient(
            to right,
            transparent 0%,
            black 8%,
            black 92%,
            transparent 100%
        );

        -webkit-mask-image: linear-gradient(
            to right,
            transparent 0%,
            black 8%,
            black 92%,
            transparent 100%
        );
    }
</style>
